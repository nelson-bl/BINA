        ")\n",
        "\n",
        "plt.xlabel(\"Benzinpreis (CHF pro Liter)\")\n",
        "plt.ylabel(\"ÖV-Fahrgäste\")\n",
        "plt.gca().yaxis.set_major_formatter(FuncFormatter(format_thousands))\n",
        "plt.grid(True, alpha=0.3)\n",
        "\n",
        "kpi_text_oev = (\n",
        "    f\"R² = {r2_oev:.3f}\\n\"\n",
        "    f\"β = {beta_oev:,.0f}\\n\"\n",
        "    f\"p = {p_oev:.5f}\"\n",
        ").replace(\",\", \"'\")\n",
        "\n",
        "add_kpi_box(kpi_text_oev)\n",
        "\n",
        "plt.tight_layout(rect=[0, 0.03, 1, 0.91])\n",
        "plt.show()\n",
        "add_plot_spacing()\n",
        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# 6) VISUAL 3 – Scatterplot Benzinpreis vs. MIV\n",
        "# ------------------------------------------------------------\n",
        "x_miv = df_step4[\"benzinpreis\"]\n",
        "y_miv = df_step4[\"miv\"]\n",
        "\n",
        "y_line_miv = model_miv.params[\"const\"] + model_miv.params[\"benzinpreis\"] * x_line\n",
        "\n",
        "plt.figure(figsize=(12, 7))\n",
        "\n",
        "plt.scatter(x_miv, y_miv, alpha=0.75)\n",
        "plt.plot(x_line, y_line_miv, linewidth=2)\n",
        "\n",
        "show_title_and_subtitle(\n",
        "    \"Auch beim MIV zeigt sich ein positiver, aber begrenzter Zusammenhang\",\n",
        "    \"Zusammenhang zwischen Benzinpreis und motorisiertem Individualverkehr (MIV)\"\n",
        ")\n",
        "\n",
        "plt.xlabel(\"Benzinpreis (CHF pro Liter)\")\n",
        "plt.ylabel(\"MIV (monatliche Summe)\")\n",
        "plt.gca().yaxis.set_major_formatter(FuncFormatter(format_thousands))\n",
        "plt.grid(True, alpha=0.3)\n",
        "\n",
        "kpi_text_miv = (\n",
        "    f\"R² = {r2_miv:.3f}\\n\"\n",
        "    f\"β = {beta_miv:,.0f}\\n\"\n",
        "    f\"p = {p_miv:.5f}\"\n",
        ").replace(\",\", \"'\")\n",
        "\n",
        "add_kpi_box(kpi_text_miv)\n",
        "\n",
        "plt.tight_layout(rect=[0, 0.03, 1, 0.91])\n",
        "plt.show()\n",
        "add_plot_spacing()\n",
        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# 7) VISUAL 4 – Korrelationsmatrix\n",
        "# ------------------------------------------------------------\n",
        "corr_df = df_step4[[\"fahrgaeste\", \"benzinpreis\", \"miv\"]].corr()\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 6))\n",
        "\n",
        "im = ax.imshow(corr_df, aspect=\"auto\")\n",
        "\n",
        "ax.set_xticks(range(len(corr_df.columns)))\n",
        "ax.set_yticks(range(len(corr_df.index)))\n",
        "ax.set_xticklabels([\"ÖV\", \"Benzinpreis\", \"MIV\"])\n",
        "ax.set_yticklabels([\"ÖV\", \"Benzinpreis\", \"MIV\"])\n",
        "\n",
        "ax.set_title(\n",
        "    \"Die Korrelationen zeigen Zusammenhänge, aber keine starke Erklärungskraft\",\n",
        "    fontsize=15,\n",
        "    pad=16\n",
        ")\n",
        "\n",
        "for i in range(corr_df.shape[0]):\n",
        "    for j in range(corr_df.shape[1]):\n",
        "        ax.text(\n",
        "            j, i,\n",
        "            f\"{corr_df.iloc[i, j]:.2f}\",\n",
        "            ha=\"center\", va=\"center\", fontsize=11\n",
        "        )\n",
        "\n",
        "plt.colorbar(im)\n",
        "plt.tight_layout(rect=[0, 0.02, 1, 0.96])\n",
        "plt.show()\n",
        "add_plot_spacing()\n",
        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# 8) Manager Summary\n",
        "# ------------------------------------------------------------\n",
        "print(\"MANAGER SUMMARY\")\n",
        "print(\"-\" * 80)\n",
