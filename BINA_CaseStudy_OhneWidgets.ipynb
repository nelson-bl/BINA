      "cell_type": "markdown",
      "source": [
        "###Datenqualität prüfen\n",
        "\n",
        "Im nächsten Schritt wird die Qualität des MIV-Datensatzes überprüft, um mögliche Unstimmigkeiten, fehlende Werte oder strukturelle Auffälligkeiten zu identifizieren und die Eignung der Daten für die weitere Analyse sicherzustellen."
      ],
      "metadata": {
        "id": "LNJU7uTQkOvK"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# --- Datenqualität prüfen MIV ---\n",
        "\n",
        "# 1. Fehlende Werte pro Spalte\n",
        "print(\"Fehlende Werte pro Spalte:\")\n",
        "display(df_miv.isnull().sum().to_frame(name=\"Anzahl fehlende Werte\"))\n",
        "\n",
        "\n",
        "# 2. Anteil fehlender Werte (%)\n",
        "print(\"\\nAnteil fehlender Werte (%):\")\n",
        "display(((df_miv.isnull().mean() * 100).round(2)).to_frame(name=\"Fehlende Werte in %\"))\n",
        "\n",
        "\n",
        "# 3. Datentypen prüfen\n",
        "print(\"\\nDatentypen:\")\n",
        "display(df_miv.dtypes.to_frame(name=\"Datentyp\"))\n",
        "\n",
        "\n",
        "# 4. Duplikate prüfen\n",
        "print(\"\\nAnzahl vollständiger Duplikate:\")\n",
        "print(df_miv.duplicated().sum())\n",
        "\n",
        "\n",
        "# 5. Leere Strings prüfen\n",
        "print(\"\\nLeere Strings pro Spalte:\")\n",
        "leere_strings = (df_miv.astype(str).apply(lambda col: col.str.strip() == \"\")).sum()\n",
        "display(leere_strings.to_frame(name=\"Anzahl leerer Strings\"))\n",
        "\n",
        "\n",
        "# 6. Zeitvariable prüfen\n",
        "print(\"\\nPrüfung Zeitvariable (DateTimeFrom):\")\n",
        "datum_test = pd.to_datetime(df_miv[\"DateTimeFrom\"], errors=\"coerce\")\n",
        "\n",
        "print(\"Nicht als Datum interpretierbare Werte:\")\n",
        "print(datum_test.isnull().sum())\n",
        "\n",
        "print(\"\\nMin / Max Datum:\")\n",
        "print(datum_test.min(), \"→\", datum_test.max())\n",
        "\n",
        "\n",
        "# 7. Zielvariable prüfen (Total)\n",
        "print(\"\\nPrüfung Zielvariable (Total):\")\n",
        "total_test = pd.to_numeric(df_miv[\"Total\"], errors=\"coerce\")\n",
        "\n",
        "print(\"Nicht numerische Werte:\")\n",
        "print(total_test.isnull().sum())\n",
        "\n",
        "print(\"\\nMin / Max Werte:\")\n",
        "print(total_test.min(), \"→\", total_test.max())\n",
        "\n",
        "print(\"\\nAnzahl Werte <= 0:\")\n",
        "print((total_test <= 0).sum())\n",
        "\n",
        "\n",
        "# 8. Überblick Füllgrad\n",
        "print(\"\\nNicht-Null-Anteil je Spalte (%):\")\n",
        "display((df_miv.count() / len(df_miv) * 100).round(2).to_frame(name=\"Füllgrad in %\"))"
      ],
