        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
        "# 2) Hilfsfunktionen\n",
        "# ------------------------------------------------------------\n",
        "def format_thousands(x, pos):\n",
        "    \"\"\"Formatiert Zahlen mit Tausendertrennzeichen.\"\"\"\n",
        "    try:\n",
        "        return f\"{int(x):,}\".replace(\",\", \"'\")\n",
        "    except:\n",
        "        return str(x)\n",
        "\n",
        "def min_max_index(series):\n",
        "    \"\"\"Indexiert eine Reihe auf Basis 100 im ersten Wert.\"\"\"\n",
        "    first_value = series.iloc[0]\n",
        "    return (series / first_value) * 100\n",
        "\n",
        "def show_title_and_subtitle(title, subtitle=None):\n",
        "    \"\"\"\n",
        "    Setzt einen sauberen Titel und optional einen Untertitel,\n",
        "    ohne Überlagerung.\n",
        "    \"\"\"\n",
        "    ax = plt.gca()\n",
        "    ax.set_title(title, fontsize=16, pad=20)\n",
        "    if subtitle:\n",
        "        plt.gcf().text(\n",
        "            0.5, 0.93, subtitle,\n",
        "            ha=\"center\", va=\"center\",\n",
        "            fontsize=11, color=\"dimgray\"\n",
        "        )\n",
        "\n",
        "def add_source_note():\n",
        "    \"\"\"Kleine methodische Notiz unter dem Plot.\"\"\"\n",
        "    plt.figtext(\n",
        "        0.01, 0.01,\n",
        "        \"Hinweis: Darstellung auf Monatsbasis; Index = 100 im ersten gemeinsamen Monat.\",\n",
        "        ha=\"left\", fontsize=9, color=\"dimgray\"\n",
        "    )\n",
        "\n",
        "def add_kpi_box(text):\n",
        "    \"\"\"KPI-Kasten rechts oben im Plot.\"\"\"\n",
        "    plt.gca().text(\n",
        "        0.98, 0.98, text,\n",
        "        transform=plt.gca().transAxes,\n",
