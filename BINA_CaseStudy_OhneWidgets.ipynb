    {
      "cell_type": "markdown",
      "source": [
        "### Datenzugriff\n",
        "\n",
        "Die Fahrgastdaten der BVB werden automatisiert aus der Open-Data-Quelle abgerufen und in ein analysierbares Format überführt. Da die Daten im XML-basierten Excel-Format vorliegen, erfolgt eine manuelle Extraktion der Tabellenstruktur und anschließende Umwandlung in einen Pandas DataFrame.\n"
      ],
      "metadata": {
        "id": "reGLLbjHhojQ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import requests\n",
        "from io import StringIO\n",
        "import xml.etree.ElementTree as ET\n",
        "\n",
        "# URL der Excel-Datei (Open Data Basel)\n",
        "url = \"https://data.bs.ch/api/v2/catalog/datasets/100075/exports/xls?use_labels=true\"\n",
        "\n",
        "# Inhalt abrufen\n",
        "response = requests.get(url)\n",
        "\n",
        "# Überprüfen des Content-Type Headers und der ersten Bytes\n",
        "content_type = response.headers.get('Content-Type')\n",
        "print(f\"Content-Type: {content_type}\")\n",
        "print(f\"Erste 100 Bytes des Inhalts: {response.content[:100]}\")\n",
        "\n",
        "# Dekodieren des Inhalts als UTF-8 String\n",
        "xml_string = response.content.decode('utf-8')\n",
        "\n",
        "# XML mit ElementTree parsen\n",
        "root = ET.fromstring(xml_string)\n",
        "\n",
        "# Namespaces definieren\n",
        "# Excel XMLSS verwendet mehrere Namespaces. Standard = 'urn:schemas-microsoft-com:office:spreadsheet'\n",
        "# und für Datentypen 'urn:schemas-microsoft-com:office:excel'\n",
        "namespaces = {\n",
        "    'ss': 'urn:schemas-microsoft-com:office:spreadsheet',\n",
        "    'o': 'urn:schemas-microsoft-com:office:office',\n",
        "    'x': 'urn:schemas-microsoft-com:office:excel',\n",
        "    'html': 'http://www.w3.org/TR/REC-html40'\n",
        "}\n",
        "\n",
        "data = []\n",
        "header = []\n",
        "is_header = True\n",
        "header_len = 0 # Speichern der ermittelten Länge des Headers\n",
        "\n",
        "# Erstes Worksheet im XML finden\n",
        "for worksheet in root.findall('.//ss:Worksheet', namespaces):\n",
        "    for table in worksheet.findall('ss:Table', namespaces):\n",
        "        for row in table.findall('ss:Row', namespaces):\n",
        "            row_data = []\n",
        "            for i, cell in enumerate(row.findall('ss:Cell', namespaces)):\n",
        "                # Wert aus dem Data-Tag innerhalb der Zelle extrahieren\n",
        "                data_element = cell.find('ss:Data', namespaces)\n",
        "                if data_element is not None:\n",
        "                    value = data_element.text\n",
        "                else:\n",
        "                    value = None\n",
        "                row_data.append(value)\n",
        "\n",
        "            # Leere Zeilen überspringen, wenn sie keine Daten enthalten\n",
        "            if any(item is not None and str(item).strip() != '' for item in row_data):\n",
        "                if is_header:\n",
        "                    header = row_data\n",
        "                    header_len = len(header) # Länge des Headers speichern\n",
        "                    is_header = False\n",
        "                else:\n",
        "                    # Sicherstellen, dass Datenzeilen der Headerlänge entsprechen\n",
        "                    if len(row_data) < header_len:\n",
        "                        row_data.extend([None] * (header_len - len(row_data)))\n",
        "                    elif len(row_data) > header_len:\n",
        "                        row_data = row_data[:header_len] # Kürzen, falls zusätzliche Spalten vorhanden sind\n",
        "                    data.append(row_data)\n",
        "        break # Nur die erste Tabelle im ersten Worksheet ist relevant\n",
        "    break # Nur das erste Worksheet ist relevant\n",
        "\n",
        "# DataFrame erstellen\n",
        "if header and data:\n",
        "    df_oev = pd.DataFrame(data, columns=header)\n",
        "else:\n",
        "    print(\"Konnte keine Daten oder Header in der XML-Datei finden.\")\n",
        "    df_oev = pd.DataFrame() # Leeren DataFrame erstellen, falls keine Daten gefunden wurden\n",
        "\n",
        "# Erste Übersicht\n",
        "df_oev.head()"
      ],
