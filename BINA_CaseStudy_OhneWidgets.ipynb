    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "import requests\n",
        "from io import BytesIO, StringIO\n",
        "\n",
        "# URL des BFS-Datensatzes\n",
        "url = \"https://dam-api.bfs.admin.ch/hub/api/dam/assets/36483232/master\"\n",
        "\n",
        "# Datei herunterladen\n",
        "response = requests.get(url)\n",
        "response.raise_for_status()\n",
        "\n",
        "# Metadaten zur Kontrolle ausgeben\n",
        "content_type = response.headers.get(\"Content-Type\")\n",
        "content_disposition = response.headers.get(\"Content-Disposition\")\n",
        "\n",
        "print(\"Content-Type:\", content_type)\n",
        "print(\"Content-Disposition:\", content_disposition)\n",
        "\n",
        "# Robust versuchen, die Datei einzulesen\n",
        "df_benzin = None\n",
        "\n",
        "# 1) Versuch: Excel\n",
        "try:\n",
        "    df_benzin = pd.read_excel(BytesIO(response.content))\n",
        "    print(\"Datei erfolgreich als Excel gelesen.\")\n",
        "except Exception as e_excel:\n",
        "    print(\"Excel-Import nicht möglich:\", e_excel)\n",
        "\n",
        "# 2) Falls Excel nicht klappt: CSV versuchen\n",
        "if df_benzin is None:\n",
        "    try:\n",
        "        text_data = response.content.decode(\"utf-8\")\n",
        "        df_benzin = pd.read_csv(StringIO(text_data))\n",
        "        print(\"Datei erfolgreich als CSV (UTF-8) gelesen.\")\n",
        "    except Exception as e_csv_utf8:\n",
        "        print(\"CSV-Import mit UTF-8 nicht möglich:\", e_csv_utf8)\n",
        "\n",
        "# 3) Falls UTF-8 nicht klappt: CSV mit latin1 versuchen\n",
        "if df_benzin is None:\n",
        "    try:\n",
        "        text_data = response.content.decode(\"latin1\")\n",
        "        df_benzin = pd.read_csv(StringIO(text_data), sep=\";\")\n",
        "        print(\"Datei erfolgreich als CSV (latin1, Semikolon) gelesen.\")\n",
        "    except Exception as e_csv_latin1:\n",
        "        print(\"CSV-Import mit latin1 nicht möglich:\", e_csv_latin1)\n",
        "\n",
        "# Prüfen, ob etwas geladen wurde\n",
        "if df_benzin is None:\n",
        "    raise ValueError(\"Die Datei konnte weder als Excel noch als CSV eingelesen werden.\")\n",
        "\n",
        "# Erste Sicht auf die Daten\n",
        "print(\"\\nErste 5 Zeilen:\")\n",
        "display(df_benzin.head())\n",
        "\n",
        "print(\"\\nSpalten:\")\n",
        "print(df_benzin.columns.tolist())\n",
        "\n",
