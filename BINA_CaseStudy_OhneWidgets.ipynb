        "print(f\"2. Der Zusammenhang ist jedoch nur moderat (R² ÖV = {r2_oev:.3f}).\")\n",
        "print(\"3. Benzinpreise sind damit ein Einflussfaktor, aber nicht der dominante Treiber des Mobilitätsverhaltens.\")\n",
        "\n",
        "if p_oev < 0.05:\n",
        "    print(\"4. Der Zusammenhang im ÖV-Modell ist statistisch signifikant.\")\n",
        "else:\n",
        "    print(\"4. Der Zusammenhang im ÖV-Modell ist statistisch nicht signifikant.\")\n",
        "\n",
        "if p_miv < 0.05:\n",
