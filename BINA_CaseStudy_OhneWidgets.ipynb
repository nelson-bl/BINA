        "\n",
        "def add_plot_spacing():\n",
        "    \"\"\"Erzeugt sichtbaren Abstand zwischen den Outputs im Notebook.\"\"\"\n",
        "    display(Markdown(\"<br><br>\"))\n",
        "\n",
        "\n",
        "# ------------------------------------------------------------\n",
